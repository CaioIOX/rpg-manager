# Configurações do Banco de Dados
DB_PASSWORD=sua_senha_super_segura_aqui

# Segredo para geração de tokens JWT
JWT_SECRET=seu_segredo_jwt_super_seguro_aqui

# Configurações de CORS (Se o frontend não estiver no mesmo domínio/porta que o backend, se não usar o proxy do Next.js)
ALLOWED_ORIGINS=http://localhost:3000,http://seu-dominio-vps.com

# URL do Backend (Para o proxy do Next.js server-side)
# Em produção via Docker Compose, deixe como http://backend:8080
BACKEND_URL=http://backend:8080

# Chaves públicas para autenticação do Google (Frontend puro)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com

# URL Pública de WebSockets (Opcional, Next.js tenta autodetectar baseado na URL)
# NEXT_PUBLIC_WS_URL=wss://seu-dominio-vps.com

# Chave da API do Google Gemini para o chatbot Lorena (Lore Keeper)
# Obtenha em: https://aistudio.google.com/app/apikey
# Se não configurada, o chatbot ficará indisponível (sem erros fatais no servidor)
GEMINI_API_KEY=sua-gemini-api-key-aqui

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=seu_email_cadastrado_no_brevo
SMTP_PASSWORD=Chave_SMTP_Fornecida_Pelo_Brevo
SMTP_FROM=seu_email_autenticado_no_brevo@dominio.com
FRONTEND_URL=http://localhost:3000
DAILY_EMAIL_LIMIT=290
